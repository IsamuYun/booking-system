# miniprogram-automator 启动配置
# 复制为 .env 并按本机环境填写

# 微信开发者工具 CLI 路径
# macOS: /Applications/wechatwebdevtools.app/Contents/MacOS/cli
# Windows: C:/Program Files (x86)/Tencent/微信web开发者工具/cli.bat
WX_CLI_PATH=/Applications/wechatwebdevtools.app/Contents/MacOS/cli

# 小程序项目根目录（指向本仓库的 miniprogram/）
WX_PROJECT_PATH=/Users/isamu/Projects/Node/booking-system/miniprogram

# automator 监听端口 (默认 9420)
WX_AUTOMATOR_PORT=9420

# 后端服务地址（utils/request.js 中 BASE_URL 默认值）
API_BASE_URL=http://192.168.0.22:5100

# 用于测试的账号
TEST_PHONE=13800000001
TEST_NAME=自动化测试员
TEST_INVITE_CODE=TEST-INVITE-2026

# 管理员账号
TEST_ADMIN_PHONE=13800000000
