page {
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.rooms-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.rooms-scroll {
  width: 100%;
  height: calc(100vh - 44px - env(safe-area-inset-top));
}

.rooms-content {
  min-height: calc(100vh + 1px);
  padding-top: 16rpx;
}

.rooms-intro {
  padding: 16rpx 32rpx 12rpx;
  color: var(--ink-3);
  font-size: 26rpx;
  line-height: 1.6;
}

.room-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 18rpx 32rpx 0;
}

.room-list-card {
  display: flex;
  min-height: 264rpx;
}

.room-list-photo {
  flex-shrink: 0;
  width: 240rpx;
  min-height: 264rpx;
  background: var(--green-50);
}

.room-list-body {
  flex: 1;
  min-width: 0;
  padding: 24rpx 28rpx;
}

.room-list-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.room-name-group {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
}

.room-name {
  color: var(--ink);
  font-size: 32rpx;
  font-weight: 700;
}

.room-en {
  color: var(--ink-4);
  font-size: 22rpx;
}

.room-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  color: var(--ink-2);
  font-size: 26rpx;
  line-height: 1.5;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.room-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.room-tag {
  gap: 8rpx;
}

.mini-icon {
  position: relative;
  flex-shrink: 0;
  width: 24rpx;
  height: 24rpx;
  color: currentColor;
}

.mini-icon::before,
.mini-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.mini-icon-users::before {
  left: 7rpx;
  top: 2rpx;
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.mini-icon-users::after {
  left: 3rpx;
  top: 14rpx;
  width: 18rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.mini-icon-area::before {
  left: 3rpx;
  top: 3rpx;
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
}

.mini-icon-area::after {
  right: 1rpx;
  bottom: 1rpx;
  width: 8rpx;
  height: 8rpx;
  border-right: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
}

.bottom-space {
  height: calc(180rpx + env(safe-area-inset-bottom));
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid var(--line);
  box-shadow: 0 -10rpx 28rpx rgba(8, 40, 33, 0.08);
  backdrop-filter: blur(18rpx);
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: var(--ink-3);
  font-size: 25rpx;
  font-weight: 500;
}

.bottom-nav-item.active {
  color: var(--green-700);
  font-weight: 700;
}

.bottom-nav-sep {
  width: 1rpx;
  height: 32rpx;
  background: var(--line-strong);
}
