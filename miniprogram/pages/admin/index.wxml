<!--pages/admin/index.wxml-->
<view class="container">
  <view class="back-bar" bindtap="goBack">
    <text class="back-btn">返回首页</text>
  </view>

  <view class="export-section">
    <view class="section-title">租赁费用结算</view>
    <view class="export-row">
      <picker mode="date" fields="month" value="{{exportMonth}}" bindchange="onExportMonthChange">
        <view class="month-picker">
          当前选择: {{exportMonth}}
        </view>
      </picker>
      <button class="export-btn" bindtap="handleExport">下载Excel</button>
    </view>
  </view>

