/* pages/import/index.wxss */

.container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 20rpx;
}

.btn-choose {
  background: #1aad19;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.file-name {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #f0f9f0;
  border-radius: 10rpx;
  border: 1rpx solid #b7e4b7;
}

.file-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.file-text {
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.file-hint {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #bbb;
}

.btn-upload {
  background: #1296db;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  width: 100%;
}

.btn-disabled {
  background: #9acde8;
}

.result-card {
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.result-success {
  background: #f0f9f0;
  border: 1rpx solid #b7e4b7;
  color: #2d7a2d;
}

.result-error {
  background: #fff2f2;
  border: 1rpx solid #f5c0c0;
  color: #c0392b;
}
