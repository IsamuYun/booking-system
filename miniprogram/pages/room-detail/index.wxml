<view class="detail-page" wx:if="{{room}}">
  <scroll-view class="detail-scroll" scroll-y="true" enhanced="true" show-scrollbar="{{false}}">
    <view class="photo-hero">
      <image class="photo-main" src="{{room.image}}" mode="aspectFill"></image>
      <view class="detail-nav">
        <view class="nav-safe"></view>
        <view class="nav-row">
          <button class="nav-back" bindtap="goBack" hover-class="is-pressed" aria-label="返回">
            <text>‹</text>
          </button>
          <text class="nav-title">{{room.name}}</text>
          <view class="nav-spacer"></view>
        </view>
      </view>
      <view class="photo-count">
        <view class="mini-icon mini-icon-image"></view>
        <text>1 / 6</text>
      </view>
    </view>

    <scroll-view class="thumb-strip" scroll-x="true" enable-flex="true" show-scrollbar="{{false}}">
      <view class="thumb-row">
        <image class="thumb active" src="{{room.image}}" mode="aspectFill"></image>
        <image class="thumb" src="/images/psycho-room-1.jpg" mode="aspectFill"></image>
        <image class="thumb" src="/images/multi-room-1.jpg" mode="aspectFill"></image>
        <image class="thumb" src="/images/psy-therapy.png" mode="aspectFill"></image>
      </view>
    </scroll-view>

    <view class="detail-head">
      <view class="title-block">
        <text class="detail-title">{{room.name}}</text>
        <text class="detail-en">{{room.en}}</text>
      </view>
      <text class="status-pill status-{{room.status}}">{{room.statusText}}</text>
    </view>

    <text class="detail-desc">{{room.desc}}</text>

    <view class="spec-grid">
      <view class="spec-tile">
        <view class="spec-icon">
          <view class="mini-icon mini-icon-users"></view>
        </view>
        <view class="spec-main">
          <text class="spec-label">容纳</text>
          <text class="spec-value">{{room.cap}}</text>
        </view>
      </view>
      <view class="spec-tile">
        <view class="spec-icon">
          <view class="mini-icon mini-icon-area"></view>
        </view>
        <view class="spec-main">
          <text class="spec-label">面积</text>
          <text class="spec-value">{{room.area}}</text>
        </view>
      </view>
      <view wx:for="{{room.tags}}" wx:key="label" class="spec-tile">
        <view class="spec-icon">
          <view class="mini-icon mini-icon-{{item.icon}}"></view>
        </view>
        <view class="spec-main">
          <text class="spec-label">{{item.label}}</text>
          <text class="spec-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <view class="section-head">
      <text class="section-title">咨询室使用状况</text>
    </view>
    <usage-calendar></usage-calendar>

    <view class="detail-note-panel">
      <text class="detail-note-text">使用状况仅供参考，具体安排请以前台确认为准。</text>
    </view>

    <view class="detail-bottom-space"></view>
  </scroll-view>
</view>
