page {
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.detail-page {
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.detail-scroll {
  width: 100%;
  height: 100vh;
}

.photo-hero {
  position: relative;
  height: 600rpx;
  background: var(--green-50);
}

.photo-main {
  display: block;
  width: 100%;
  height: 100%;
}

.detail-nav {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  z-index: 2;
  color: #ffffff;
}

.nav-safe {
  height: env(safe-area-inset-top);
}

.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 0 28rpx;
}

.nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.28);
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1;
  backdrop-filter: blur(12rpx);
}

.nav-back text {
  transform: translateY(-4rpx);
}

.nav-title {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.36);
}

.nav-spacer {
  width: 68rpx;
  height: 68rpx;
}

.photo-count {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.4);
  color: #ffffff;
  font-size: 24rpx;
  backdrop-filter: blur(12rpx);
}

.thumb-strip {
  display: block;
  width: 100%;
  white-space: nowrap;
}

.thumb-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 32rpx 0;
}

.thumb {
  flex-shrink: 0;
  width: 144rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: var(--green-50);
}

.thumb.active {
  border: 4rpx solid var(--green-600);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 36rpx 32rpx 0;
}

.title-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.detail-title {
  color: var(--ink);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.detail-en {
  color: var(--ink-3);
  font-size: 26rpx;
}

.detail-desc {
  display: block;
  padding: 22rpx 32rpx 0;
  color: var(--ink-2);
  font-size: 28rpx;
  line-height: 1.65;
}

.spec-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 32rpx 32rpx 0;
}

.spec-tile {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-width: 0;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.spec-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  background: var(--green-50);
  color: var(--green-600);
}

.spec-main {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.spec-label {
  color: var(--ink-3);
  font-size: 22rpx;
}

.spec-value {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-head {
  padding: 0 32rpx;
}

.detail-note-panel {
  padding: 40rpx 32rpx 0;
}

.detail-note-text {
  display: block;
  padding: 22rpx 28rpx;
  border-radius: 20rpx;
  background: var(--green-50);
  color: var(--ink-4);
  font-size: 24rpx;
  line-height: 1.45;
  text-align: center;
}

.detail-bottom-space {
  height: calc(40rpx + env(safe-area-inset-bottom));
}

.mini-icon {
  position: relative;
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  color: currentColor;
}

.mini-icon::before,
.mini-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.mini-icon-users::before {
  left: 8rpx;
  top: 2rpx;
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.mini-icon-users::after {
  left: 4rpx;
  top: 16rpx;
  width: 20rpx;
  height: 9rpx;
  border: 2rpx solid currentColor;
  border-bottom: 0;
  border-radius: 14rpx 14rpx 0 0;
}

.mini-icon-area::before {
  left: 4rpx;
  top: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 5rpx;
}

.mini-icon-area::after {
  right: 1rpx;
  bottom: 1rpx;
  width: 9rpx;
  height: 9rpx;
  border-right: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
}

.mini-icon-heart::before {
  left: 5rpx;
  top: 7rpx;
  width: 18rpx;
  height: 16rpx;
  border-left: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
  border-radius: 0 0 0 8rpx;
  transform: rotate(-45deg);
}

.mini-icon-sun::before {
  left: 8rpx;
  top: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.mini-icon-sun::after {
  left: 13rpx;
  top: 1rpx;
  width: 2rpx;
  height: 26rpx;
  background: currentColor;
  box-shadow: 0 0 0 currentColor;
}

.mini-icon-ear::before {
  left: 7rpx;
  top: 3rpx;
  width: 14rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-left-width: 0;
  border-radius: 0 16rpx 16rpx 0;
}

.mini-icon-ear::after {
  left: 9rpx;
  bottom: 3rpx;
  width: 12rpx;
  height: 8rpx;
  border-bottom: 2rpx solid currentColor;
  border-radius: 0 0 10rpx 10rpx;
}

.mini-icon-wind::before {
  left: 2rpx;
  top: 8rpx;
  width: 22rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-radius: 999rpx;
}

.mini-icon-wind::after {
  left: 6rpx;
  top: 16rpx;
  width: 18rpx;
  height: 8rpx;
  border-top: 2rpx solid currentColor;
  border-radius: 999rpx;
}

.mini-icon-image::before {
  left: 3rpx;
  top: 5rpx;
  width: 22rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 5rpx;
}

.mini-icon-image::after {
  left: 8rpx;
  top: 14rpx;
  width: 12rpx;
  height: 8rpx;
  border-left: 2rpx solid currentColor;
  border-top: 2rpx solid currentColor;
  transform: rotate(45deg);
}
