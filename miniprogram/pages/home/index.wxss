/* pages/home/index.wxss */
page {
  background: #ffffff;
  height: 100vh;
  overflow: hidden;
}

.home-page {
  position: relative;
  display: block;
  height: 100vh;
  overflow: hidden;
  background: #ffffff;
}

.home-scroll {
  display: block;
  width: 100%;
  height: 100vh;
}

.home-content {
  display: block;
  min-height: calc(100vh + 1px);
}

.home-hero {
  position: relative;
  height: 492rpx;
  margin-top: 100px;
  padding: 0;
  overflow: hidden;
  background: #ffffff;
}

.hero-photo {
  display: block;
  width: 100%;
  height: 100%;
  opacity: 1;
}

.home-stats {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  margin: -72rpx 32rpx 0;
  padding: 34rpx 0;
}

.section-head {
  padding: 0 32rpx;
}

.section-more {
  color: var(--ink-3);
  font-size: 26rpx;
  line-height: 1.4;
}

.room-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 32rpx 8rpx;
}

.room-mini-card {
  position: relative;
  min-width: 0;
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: var(--shadow-card);
}

.room-mini-card-wide {
  grid-column: 1 / 3;
}

.room-mini-photo {
  display: block;
  width: 100%;
  height: 188rpx;
  background: var(--green-50);
}

.room-mini-photo-wide {
  height: 320rpx;
}

.room-status {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
}

.room-mini-body {
  padding: 18rpx 22rpx 22rpx;
}

.room-title-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
}

.room-mini-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.room-mini-en {
  color: var(--ink-4);
  font-size: 22rpx;
}

.room-mini-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 12rpx;
  color: var(--ink-3);
  font-size: 24rpx;
}

.mini-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.mini-icon {
  position: relative;
  flex-shrink: 0;
  width: 24rpx;
  height: 24rpx;
  color: currentColor;
}

.mini-icon::before,
.mini-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.mini-icon-users::before {
  left: 7rpx;
  top: 2rpx;
  width: 10rpx;
  height: 10rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.mini-icon-users::after {
  left: 3rpx;
  top: 14rpx;
  width: 18rpx;
  height: 8rpx;
  border: 2rpx solid currentColor;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
}

.mini-icon-area::before {
  left: 3rpx;
  top: 3rpx;
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 4rpx;
}

.mini-icon-area::after {
  right: 1rpx;
  bottom: 1rpx;
  width: 8rpx;
  height: 8rpx;
  border-right: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
}

.mini-icon-pin::before {
  left: 5rpx;
  top: 2rpx;
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid currentColor;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
}

.mini-icon-pin::after {
  left: 10rpx;
  top: 7rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
}

.mini-icon-clock::before {
  left: 2rpx;
  top: 2rpx;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid currentColor;
  border-radius: 50%;
}

.mini-icon-clock::after {
  left: 11rpx;
  top: 6rpx;
  width: 7rpx;
  height: 8rpx;
  border-left: 2rpx solid currentColor;
  border-bottom: 2rpx solid currentColor;
}

.mini-icon-phone::before {
  left: 5rpx;
  top: 3rpx;
  width: 14rpx;
  height: 18rpx;
  border: 2rpx solid currentColor;
  border-radius: 5rpx;
  transform: rotate(-18deg);
}

.mini-icon-phone::after {
  left: 10rpx;
  bottom: 5rpx;
  width: 4rpx;
  height: 2rpx;
  border-radius: 2rpx;
  background: currentColor;
}

.admin-head {
  margin-top: 44rpx;
}

.about-card {
  margin: 0 32rpx;
  padding: 30rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
}

.info-list {
  margin: 0 32rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-height: 132rpx;
  padding: 22rpx 26rpx;
  border-bottom: 1rpx solid var(--line);
}

.info-row.last {
  border-bottom: 0;
}

.info-icon-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: var(--green-50);
  color: var(--green-600);
}

.info-label {
  flex-shrink: 0;
  min-width: 128rpx;
  color: var(--ink-2);
  font-size: 28rpx;
  font-weight: 500;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: right;
}

.bottom-space {
  height: calc(180rpx + env(safe-area-inset-bottom));
}

.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 32rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid var(--line);
  box-shadow: 0 -10rpx 28rpx rgba(8, 40, 33, 0.08);
  backdrop-filter: blur(18rpx);
}

.bottom-nav-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  color: var(--ink-3);
  font-size: 26rpx;
  font-weight: 500;
}

.bottom-nav-item.active {
  color: var(--green-700);
  font-weight: 700;
}

.bottom-nav-sep {
  width: 1rpx;
  height: 32rpx;
  background: var(--line-strong);
}
