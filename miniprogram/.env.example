# Copy this file to .env and set the real server URLs.

# Active API server for the mini program: test or production
MINIPROGRAM_SERVER_ENV=test

# Test server.
# WeChat DevTools simulator can use 127.0.0.1.
# Real-device debugging must use this computer's current Wi-Fi/hotspot IP.
MINIPROGRAM_TEST_BASE_URL=http://127.0.0.1:5100

# Production server
MINIPROGRAM_PRODUCTION_BASE_URL=http://124.220.171.165:3000
