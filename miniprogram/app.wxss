/* 全局的样式文件 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0;
  box-sizing: border-box;
}

/* 通用的顶部返回栏样式 */
.back-bar {
  padding: 10rpx;
  background-color: #FFFFFF;
  display: block;
  width: 100%;
  border-bottom: 1px solid #999999;
  margin-bottom: 10rpx;
  margin-top: 10rpx;
}

.back-btn {
  font-size: 14px;
  color: #2B7FFF;
  display: block;
  box-shadow: 0px 0px 10px 1px #999;
  border-radius: 3px;
  width: 160rpx;

}

.back-icon {
  font-size: 18px;
  font-weight: bold;
  color: #666;
}
