# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 服务监听端口（生产环境建议 127.0.0.1，由 Nginx 代理）
PORT=5100
HOST=127.0.0.1

# SQLite 数据库文件路径
DB_PATH=/app/server/data/database.sqlite

# 管理后台 JWT 密钥（生产环境务必设置为随机字符串）
# 生成命令：openssl rand -base64 48
ADMIN_JWT_SECRET=change_this_to_a_random_secret_string

# 微信小程序凭据（可选）
# WECHAT_APP_ID=your_wechat_app_id
# WECHAT_APP_SECRET=your_wechat_app_secret
